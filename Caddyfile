{$PANEL_DOMAIN} {
    reverse_proxy scheduler:8000
}

# Vita — календарь жизни; контейнер живёт в соседнем ~/vita (порт 8788 хоста)
{$VITA_DOMAIN} {
    # DNS-over-HTTPS для «Сетевой блокировки» Vita Focus → AdGuard Home (~/vita)
    handle /dns-query* {
        reverse_proxy host.docker.internal:8083
    }
    handle {
        reverse_proxy host.docker.internal:8788
    }
}

# ghostline-auto
# Ghostline (~/arb-dashboard, порт 8790) — блок обязан жить В РЕПО:
# деплой yoy перезаписывает Caddyfile на сервере, и дописанное только там теряется.
ghostline-arb.duckdns.org {
    reverse_proxy host.docker.internal:8790
}
