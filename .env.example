# Скопируй в .env и заполни. Файл .env в git НЕ коммитится.

# Домен панели (например, из DuckDNS). На него Caddy автоматически
# получит HTTPS-сертификат. Должен указывать на IP этого сервера.
PANEL_DOMAIN=example.duckdns.org

# Часовой пояс для расписаний (иначе сервер считает по UTC).
TZ=Europe/Moscow

# (необязательно) Ключ подписи сессий входа. Если оставить пустым —
# сгенерируется автоматически и сохранится в profiles/secret.key.
# SECRET_KEY=
